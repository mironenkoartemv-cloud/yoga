# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/yoga_db

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# SMS (заглушка — вставить реальный ключ SMSC / МТС Exolve)
SMS_PROVIDER=stub
SMS_API_KEY=STUB
SMS_SENDER=YogaApp

# Telegram Bot (заглушка — вставить BOT_TOKEN от @BotFather)
TELEGRAM_BOT_TOKEN=STUB
TELEGRAM_BOT_NAME=STUB

# ЮKassa (заглушка — вставить SHOP_ID и SECRET_KEY из ЛК ЮKassa)
YUKASSA_SHOP_ID=STUB
YUKASSA_SECRET_KEY=STUB
YUKASSA_RETURN_URL=http://localhost:3000/payment/success

# Firebase Push (заглушка — вставить JSON из Firebase Console)
FIREBASE_SERVICE_ACCOUNT={}

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# WebRTC TURN (для дева хватит STUN Google, для прода нужен coturn)
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
