# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/yoga_db

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# SMS
SMS_PROVIDER=stub
SMS_API_KEY=STUB
SMS_SENDER=YogaApp

# SMS через МТС Exolve
# Вариант A: для теста укажите купленный/тестовый номер Exolve в EXOLVE_SMS_SENDER.
# Вариант B: после согласования альфа-имени укажите его в EXOLVE_SMS_SENDER.
# Номера лучше хранить в формате 79991112233, без плюса.
EXOLVE_API_KEY=STUB
EXOLVE_SMS_SENDER=79991112233

# Telegram Bot (заглушка — вставить BOT_TOKEN от @BotFather)
TELEGRAM_BOT_TOKEN=STUB
TELEGRAM_BOT_NAME=STUB

# ЮKassa (заглушка — вставить SHOP_ID и SECRET_KEY из ЛК ЮKassa)
YUKASSA_SHOP_ID=STUB
YUKASSA_SECRET_KEY=STUB
YUKASSA_RETURN_URL=http://localhost:3000/payment/success

# Firebase Push (заглушка — вставить JSON из Firebase Console)
FIREBASE_SERVICE_ACCOUNT={}

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# WebRTC TURN (для дева хватит STUN Google, для прода нужен coturn)
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
